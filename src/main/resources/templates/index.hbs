<html>
<head>
    <title>{{title}}</title>
    <style>
        body { font-family: sans-serif; margin: 2em; }
        .section { margin-bottom: 2em; padding: 1em; border: 1px solid #ccc; border-radius: 8px; }
        h1 { color: #333; }
        button { padding: 0.5em 1em; cursor: pointer; }
        .weather-btns button { margin-right: 0.5em; }
    </style>
</head>
<body>
    <div id="status-message" style="position: fixed; top: 10px; right: 10px; padding: 10px; border-radius: 5px; display: none; z-index: 1000;"></div>

    <h1>{{title}}</h1>
    
    <div class="section">
        <p>Current Simulation Mode: <strong>{{mode}}</strong></p>
    </div>

    {{#if isManual}}
    <div class="section">
        <h2>Temperature Control</h2>
        <form action="/temperature" method="post" class="ajax-form">
            <input type="number" step="0.1" name="value" placeholder="20.0" required>
            <button type="submit">Set Temperature</button>
        </form>
    </div>

    <div class="section">
        <h2>Weather Control</h2>
        <form action="/weather" method="post" class="weather-btns ajax-form">
            <button name="value" value="SUNNY" type="submit">Sunny</button>
            <button name="value" value="CLOUDY" type="submit">Cloudy</button>
            <button name="value" value="RAINY" type="submit">Rainy</button>
        </form>
    </div>
    {{else}}
    <div class="section">
        <p><em>Manual overrides are disabled because the system is using the <strong>{{mode}}</strong> environment.</em></p>
    </div>
    {{/if}}

    <div class="section">
        <h2>Device Controls</h2>
        
        <div style="margin-bottom: 1em;">
            <h3>AirCondition</h3>
            <form action="/aircondition" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="true" type="submit">Turn ON</button>
            </form>
            <form action="/aircondition" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="false" type="submit">Turn OFF</button>
            </form>
        </div>

        <div style="margin-bottom: 1em;">
            <h3>MediaStation</h3>
            <form action="/mediastation-play" method="post" style="display: inline;" class="ajax-form">
                <button type="submit">Play Movie</button>
            </form>
            <form action="/mediastation-stop" method="post" style="display: inline;" class="ajax-form">
                <button type="submit">Stop Movie</button>
            </form>
        </div>

        <div style="margin-bottom: 1em;">
            <h3>Blinds</h3>
            <form action="/blinds" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="true" type="submit">Close Blinds</button>
            </form>
            <form action="/blinds" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="false" type="submit">Open Blinds</button>
            </form>
        </div>
    </div>

    <script>
        document.querySelectorAll('.ajax-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const url = this.action;
                const method = this.method;
                const formData = new FormData(this);
                
                // If the button clicked has a value (like in Weather or Blinds), add it to formData
                if (e.submitter && e.submitter.name && e.submitter.value) {
                    formData.append(e.submitter.name, e.submitter.value);
                }

                const statusDiv = document.getElementById('status-message');
                
                fetch(url, {
                    method: method,
                    body: new URLSearchParams(formData)
                })
                .then(response => response.text())
                .then(text => {
                    statusDiv.textContent = text;
                    statusDiv.style.backgroundColor = '#d4edda';
                    statusDiv.style.color = '#155724';
                    statusDiv.style.display = 'block';
                    setTimeout(() => { statusDiv.style.display = 'none'; }, 3000);
                })
                .catch(error => {
                    statusDiv.textContent = 'Error: ' + error;
                    statusDiv.style.backgroundColor = '#f8d7da';
                    statusDiv.style.color = '#721c24';
                    statusDiv.style.display = 'block';
                    setTimeout(() => { statusDiv.style.display = 'none'; }, 5000);
                });
            });
        });
    </script>

    <div class="section">
        <h2>Run Instructions</h2>
        <p>To restart the system in a different mode, use the following commands:</p>
        <ul>
            <li><strong>Internal Simulation (Default):</strong><br><code>./gradlew run</code></li>
            <li><strong>External MQTT Simulation:</strong><br><code>./gradlew run --args="--external"</code></li>
            <li><strong>Manual Mode (No Simulation):</strong><br><code>./gradlew run --args="--manual"</code></li>
        </ul>
        <p><small><em>Note: You can also use <code>-Dexec.args="--flag"</code> instead of <code>--args="--flag"</code>.</em></small></p>
    </div>
</body>
</html>

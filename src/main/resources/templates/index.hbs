<html>

<head>
    <title>{{title}}</title>
    <style>
        body {
            font-family: sans-serif;
            margin: 2em;
        }

        .section {
            margin-bottom: 2em;
            padding: 1em;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        h1 {
            color: #333;
        }

        button {
            padding: 0.5em 1em;
            cursor: pointer;
        }

        .weather-btns button {
            margin-right: 0.5em;
        }

        .status-badge {
            font-size: 0.8em;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 10px;
            vertical-align: middle;
            color: white;
            background-color: #777;
        }

        .status-on,
        .status-playing,
        .status-open {
            background-color: #28a745;
        }

        .status-off,
        .status-idle,
        .status-closed {
            background-color: #dc3545;
        }

        .connection-status {
            background-color: transparent !important;
            font-weight: bold;
        }

        .conn-connected {
            color: #28a745;
            border-color: #28a745;
        }

        .conn-disconnected {
            color: #dc3545;
            border-color: #dc3545;
        }

        select {
            padding: 0.5em;
            background-color: #fff;
            color: #333;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        @media (prefers-color-scheme: dark) {
            body {
                background-color: #121212;
                color: #e0e0e0;
            }

            h1,
            h2,
            h3 {
                color: #ffffff;
            }

            .section {
                background-color: #1e1e1e;
                border-color: #333;
            }

            button {
                background-color: #333;
                color: #fff;
                border: 1px solid #555;
            }

            button:hover {
                background-color: #444;
            }

            input {
                background-color: #333;
                color: #fff;
                border: 1px solid #555;
            }

            select {
                background-color: #333;
                color: #fff;
                border-color: #555;
            }

            .conn-connected {
                color: #00ffaa;
                border-color: #00ffaa;
            }

            .conn-disconnected {
                color: #ff3e3e;
                border-color: #ff3e3e;
            }
        }
    </style>
</head>

<body>
    <div id="status-message"
        style="position: fixed; top: 10px; right: 10px; padding: 10px; border-radius: 5px; display: none; z-index: 1000;">
    </div>

    <div class="section">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <p>MODE::<strong>{{mode}}</strong></p>
            <div id="connection-status" class="status-badge connection-status conn-disconnected">DISCONNECTED</div>
        </div>
    </div>

    <div class="section">
        <h2>Environment Telemetry</h2>
        <div style="display: flex; justify-content: space-around; text-align: center;">
            <div>
                <div style="font-size: 0.8em; margin-bottom: 5px;">AMBIENT_TEMP</div>
                <div style="font-size: 2.5em; font-weight: bold;"><span id="temp-emoji">{{tempEmoji}}</span> <span
                        id="temperature-val">{{temperature}}</span>°C</div>
            </div>
            <div>
                <div style="font-size: 0.8em; margin-bottom: 5px;">WEATHER_SENSOR</div>
                <div style="font-size: 2.5em; font-weight: bold; text-transform: uppercase;"><span
                        id="weather-emoji">{{weatherEmoji}}</span> <span id="weather-val">{{weather}}</span></div>
            </div>
        </div>
    </div>

    {{#if isManual}}
    <div class="section">
        <h2>Temperature Control</h2>
        <form action="/temperature" method="post" class="ajax-form" style="display: flex; gap: 1rem;">
            <input type="number" step="0.1" name="value" required>
            <button type="submit">Set Temperature</button>
        </form>
    </div>
    <div class="section">
        <h2>Weather Control</h2>
        <div class="weather-btns">
            <form action="/weather" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="SUNNY" type="submit">Sunny</button>
            </form>
            <form action="/weather" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="CLOUDY" type="submit">Cloudy</button>
            </form>
            <form action="/weather" method="post" style="display: inline;" class="ajax-form">
                <button name="value" value="RAINY" type="submit">Rainy</button>
            </form>
        </div>
    </div>
    {{/if}}

    <div class="section">
        <h3>AirCondition <span id="aircondition-status" class="status-badge {{acClass}}">{{acState}}</span></h3>
        <form action="/aircondition" method="post" style="display: inline;" class="ajax-form">
            <button name="value" value="true" type="submit">Turn ON</button>
        </form>
        <form action="/aircondition" method="post" style="display: inline;" class="ajax-form">
            <button name="value" value="false" type="submit">Turn OFF</button>
        </form>
    </div>

    <div class="section">
        <h3>MediaStation <span id="mediastation-status" class="status-badge {{mediaClass}}">{{mediaState}}</span></h3>
        <div style="margin-bottom: 1em;">
            <form action="/mediastation-play" method="post" style="display: inline;" class="ajax-form">
                <button type="submit">Play Movie</button>
            </form>
            <form action="/mediastation-stop" method="post" style="display: inline;" class="ajax-form">
                <button type="submit">Stop Movie</button>
            </form>
        </div>
    </div>

    <div class="section">
        <h3>Blinds <span id="blinds-status" class="status-badge {{blindsClass}}">{{blindsState}}</span></h3>
        <form action="/blinds" method="post" style="display: inline;" class="ajax-form">
            <button name="value" value="true" type="submit">Close Blinds</button>
        </form>
        <form action="/blinds" method="post" style="display: inline;" class="ajax-form">
            <button name="value" value="false" type="submit">Open Blinds</button>
        </form>
    </div>

    <div class="section">
        <h2>Fridge</h2>

        <div style="display: flex; gap: 2em; margin-bottom: 1em; background: rgba(0,0,0,0.03); padding: 10px; border-radius: 8px; justify-content: space-around;">
            <div style="text-align: center;">
                <div style="font-size: 0.8em; color: #777;">WEIGHT</div>
                <div style="font-size: 1.2em; font-weight: bold;"><span id="fridge-weight">{{fridgeCurrentWeight}}</span> / {{fridgeMaxWeight}} kg</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 0.8em; color: #777;">VOLUME</div>
                <div style="font-size: 1.2em; font-weight: bold;"><span id="fridge-volume">{{fridgeCurrentVolume}}</span> / {{fridgeMaxVolume}} items</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2em;">
            <div>
                <h3>Inventory</h3>
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9em;">
                    <thead>
                        <tr style="border-bottom: 1px solid #ccc;">
                            <th style="text-align: left; padding: 5px;">ITEM</th>
                            <th style="text-align: center; padding: 5px;">QTY</th>
                            <th style="text-align: right; padding: 5px;">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each fridgeProducts}}
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 8px;">{{product.name}} <small
                                    style="color: #777;">({{product.weight}}kg, ${{product.price}})</small></td>
                            <td style="text-align: center; font-weight: bold;">{{quantity}}</td>
                            <td style="text-align: right;">
                                <form action="/fridge/consume" method="post" class="ajax-form" style="display: inline;">
                                    <button name="productName" value="{{product.name}}" type="submit"
                                        style="font-size: 0.7em; padding: 2px 5px; margin: 0; color: #ff3e3e; border-color: #ff3e3e;">CONSUME</button>
                                </form>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>

                <h3 style="margin-top: 1.5em;">Order Manual</h3>
                <form action="/fridge/order" method="post" class="ajax-form"
                    style="display: flex; flex-direction: column; gap: 0.5em;">
                    <select name="productName" required>
                        <option value="" disabled selected>Select Product</option>
                        <option value="Eggs">Eggs</option>
                        <option value="Milk">Milk</option>
                        <option value="Beer">Beer</option>
                    </select>
                    <input type="number" name="quantity" value="1" min="1" required>
                    <button type="submit">Place Order</button>
                </form>
            </div>

            <div>
                <h3>Order History</h3>
                <div
                    style="max-height: 300px; overflow-y: auto; background: rgba(0,0,0,0.05); padding: 10px; border: 1px solid #eee; font-size: 0.8em;">
                    {{#each fridgeHistory}}
                    <div style="margin-bottom: 8px; padding-bottom: 5px; border-bottom: 1px dashed #ccc;">
                        <div style="display: flex; justify-content: space-between;">
                            <span style="font-weight: bold;">ID: {{orderId}}</span>
                            <span style="{{#if successful}}color: #28a745;{{else}}color: #dc3545;{{/if}}">[{{#if
                                successful}}SUCCESS{{else}}FAILED{{/if}}]</span>
                        </div>
                        <div>ORDER: {{quantity}}x {{product.name}}</div>
                        <div style="text-align: right; opacity: 0.7;">TOTAL: ${{totalCost}}</div>
                    </div>
                    {{else}}
                    <div style="opacity: 0.5; font-style: italic;">No history entries</div>
                    {{/each}}
                </div>
            </div>
        </div>
    </div>

    <script>
        const statusBadge = document.getElementById('connection-status');

        // SSE Listener
        const eventSource = new EventSource('/events');

        eventSource.onopen = function () {
            statusBadge.textContent = 'CONNECTED';
            statusBadge.classList.remove('conn-disconnected');
            statusBadge.classList.add('conn-connected');
        };

        eventSource.onerror = function (e) {
            console.error("SSE Error: ", e);
            statusBadge.textContent = 'DISCONNECTED';
            statusBadge.classList.remove('conn-connected');
            statusBadge.classList.add('conn-disconnected');
        };

        eventSource.addEventListener('heartbeat', function (e) {
            statusBadge.style.opacity = '0.5';
            setTimeout(() => statusBadge.style.opacity = '1', 200);
        });

        eventSource.addEventListener('aircondition', function (e) {
            const status = document.getElementById('aircondition-status');
            status.textContent = e.data;
            status.className = 'status-badge ' + (e.data === 'ON' ? 'status-on' : 'status-off');
        });

        eventSource.addEventListener('blinds', function (e) {
            const status = document.getElementById('blinds-status');
            status.textContent = e.data;
            status.className = 'status-badge ' + (e.data === 'CLOSED' ? 'status-closed' : 'status-open');
        });

        eventSource.addEventListener('mediastation', function (e) {
            const status = document.getElementById('mediastation-status');
            status.textContent = e.data;
            status.className = 'status-badge ' + (e.data === 'PLAYING' ? 'status-playing' : 'status-idle');
        });

        eventSource.addEventListener('temperature', function (e) {
            const temp = parseFloat(e.data);
            document.getElementById('temperature-val').textContent = e.data;
            const emojiEl = document.getElementById('temp-emoji');
            if (temp < 10) emojiEl.textContent = '❄️';
            else if (temp < 20) emojiEl.textContent = '🌡️';
            else if (temp < 30) emojiEl.textContent = '☀️';
            else emojiEl.textContent = '🔥';
        });

        eventSource.addEventListener('weather', function (e) {
            document.getElementById('weather-val').textContent = e.data;
            const emojiEl = document.getElementById('weather-emoji');
            const condition = e.data.toUpperCase();
            if (condition.includes('SUNNY')) emojiEl.textContent = '☀️';
            else if (condition.includes('CLOUDY')) emojiEl.textContent = '☁️';
            else if (condition.includes('RAINY')) emojiEl.textContent = '🌧️';
            else emojiEl.textContent = '🛸';
        });

        eventSource.addEventListener('fridge-update', function (e) {
            console.log("Fridge updated, reloading data...");
            setTimeout(() => window.location.reload(), 1000);
        });

        // AJAX Form Handler
        document.querySelectorAll('.ajax-form').forEach(form => {
            form.addEventListener('submit', function (e) {
                e.preventDefault();

                const url = this.action;
                const method = this.method;
                const formData = new FormData(this);

                if (e.submitter && e.submitter.name && e.submitter.value) {
                    formData.append(e.submitter.name, e.submitter.value);
                }

                const statusDiv = document.getElementById('status-message');

                fetch(url, {
                    method: method,
                    body: new URLSearchParams(formData)
                })
                    .then(response => response.text())
                    .then(text => {
                        statusDiv.textContent = text;
                        statusDiv.style.backgroundColor = '#d4edda';
                        statusDiv.style.color = '#155724';
                        statusDiv.style.display = 'block';
                        setTimeout(() => { statusDiv.style.display = 'none'; }, 3000);
                    })
                    .catch(error => {
                        statusDiv.textContent = 'Error: ' + error;
                        statusDiv.style.backgroundColor = '#f8d7da';
                        statusDiv.style.color = '#721c24';
                        statusDiv.style.display = 'block';
                        setTimeout(() => { statusDiv.style.display = 'none'; }, 5000);
                    });
            });
        });
    </script>
</body>

</html>